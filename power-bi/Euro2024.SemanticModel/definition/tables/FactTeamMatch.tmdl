	partition FactTeamMatch = m
		mode: import
		source = ```
				let
				    HomeBase = Table.RenameColumns(
				        Table.SelectColumns(StgMatches, {
				            "MatchID", "HomeTeamID", "AwayTeamID", "AwayTeamName", "HomeScore", "AwayScore"
				        }),
				        {
				            {"HomeTeamID", "TeamID"}, {"AwayTeamID", "OpponentTeamID"},
				            {"AwayTeamName", "OpponentTeamName"},
				            {"HomeScore", "GoalsFor"}, {"AwayScore", "GoalsAgainst"}
				        }
				    ),
				    HomeWithRole = Table.AddColumn(HomeBase, "IsHome", each true, type logical),
				    HomeRows = Table.AddColumn(
				        HomeWithRole,
				        "ScoreLabel",
				        each Text.From([GoalsFor]) & "–" & Text.From([GoalsAgainst]),
				        type text
				    ),
				    AwayBase = Table.RenameColumns(
				        Table.SelectColumns(StgMatches, {
				            "MatchID", "AwayTeamID", "HomeTeamID", "HomeTeamName", "AwayScore", "HomeScore"
				        }),
				        {
				            {"AwayTeamID", "TeamID"}, {"HomeTeamID", "OpponentTeamID"},
				            {"HomeTeamName", "OpponentTeamName"},
				            {"AwayScore", "GoalsFor"}, {"HomeScore", "GoalsAgainst"}
				        }
				    ),
				    AwayWithRole = Table.AddColumn(AwayBase, "IsHome", each false, type logical),
				    AwayRows = Table.AddColumn(
				        AwayWithRole,
				        "ScoreLabel",
				        each Text.From([GoalsFor]) & "–" & Text.From([GoalsAgainst]),
				        type text
				    ),
				    CombinedFact = Table.Combine({HomeRows, AwayRows}),
				    FactRows = Table.SelectColumns(
				        CombinedFact, {
				            "MatchID", "TeamID", "OpponentTeamID", "OpponentTeamName",
				            "IsHome", "GoalsFor", "GoalsAgainst", "ScoreLabel"
				        }
				    ),
				    TypedFact = Table.TransformColumnTypes(
				        FactRows, 
				        {
				            {"MatchID", Int64.Type}, 
				            {"TeamID", Int64.Type},
				            {"OpponentTeamID", Int64.Type}, 
				            {"OpponentTeamName", type text},
				            {"IsHome", type logical}, 
				            {"GoalsFor", Int64.Type},
				            {"GoalsAgainst", Int64.Type}, 
				            {"ScoreLabel", type text}
				        }
				    ),
				    InvalidRows = Table.SelectRows(
				        TypedFact, 
				        each
				            [MatchID] = null 
				                or [TeamID] = null 
				                or [OpponentTeamID] = null
				                or [OpponentTeamName] = null 
				                or [OpponentTeamName] = "" 
				                or [IsHome] = null
				                or [GoalsFor] = null 
				                or [GoalsAgainst] = null 
				                or [ScoreLabel] = null
				                or [TeamID] = [OpponentTeamID]
				    
				    ),
				    DistinctKeys = Table.Distinct(
				        Table.SelectColumns(TypedFact, {"MatchID", "TeamID"})
				    ),
				    MatchChecks = Table.Group(
				        TypedFact, 
				        {"MatchID"}, 
				        {
				            {"RowCount", each Table.RowCount(_), Int64.Type},
				            {"TeamCount", each List.Count(List.Distinct([TeamID])), Int64.Type},
				            {"HomeCount", each List.Count(List.Select([IsHome], each _ = true)), Int64.Type}
				        }
				    ),
				    JoinedSource = Table.NestedJoin(
				        TypedFact, {"MatchID"}, StgMatches, {"MatchID"}, "Source", JoinKind.LeftOuter),
				    ExpandedSource = Table.ExpandTableColumn(
				        JoinedSource,
				        "Source",
				        {"HomeTeamID", "HomeTeamName", "AwayTeamID", "AwayTeamName", "HomeScore", "AwayScore"},
				        {"HomeTeamID", "HomeTeamName", "AwayTeamID", "AwayTeamName", "HomeScore", "AwayScore"}
				    ),
				    InvalidAssignments = Table.SelectRows(
				        ExpandedSource, 
				        each
				            [HomeTeamID] = null 
				                or [AwayTeamID] = null
				        or (
				            [IsHome] = true 
				                and (
				                    [TeamID] <> [HomeTeamID] 
				                    or [OpponentTeamID] <> [AwayTeamID]
				                    or [OpponentTeamName] <> [AwayTeamName]
				                    or [GoalsFor] <> [HomeScore] 
				                    or [GoalsAgainst] <> [AwayScore]
				                    or [ScoreLabel] <> (
				                        Text.From([HomeScore]) & "–" & Text.From([AwayScore])
				                    )
				            )
				        )
				        or (
				            [IsHome] = false 
				                and (
				                    [TeamID] <> [AwayTeamID] 
				                    or [OpponentTeamID] <> [HomeTeamID]
				                    or [OpponentTeamName] <> [HomeTeamName]
				                    or [GoalsFor] <> [AwayScore] 
				                    or [GoalsAgainst] <> [HomeScore]
				                    or [ScoreLabel] <> (
				                        Text.From([AwayScore]) & "–" & Text.From([HomeScore])
				                    )
				            )
				        )
				    
				    ),
				    HasWrongRowCount =
				        Table.RowCount(TypedFact) <> ProjectConfig[TeamsPerMatch] * Table.RowCount(StgMatches),
				    HasDuplicateKeys = Table.RowCount(TypedFact) <> Table.RowCount(DistinctKeys),
				    HasInvalidMatchCounts = not Table.IsEmpty(Table.SelectRows(MatchChecks, each
				        [RowCount] <> ProjectConfig[TeamsPerMatch]
				        or [TeamCount] <> ProjectConfig[TeamsPerMatch]
				        or [HomeCount] <> 1
				    )),
				    Output =
				        if not Table.IsEmpty(InvalidRows) then error "FactTeamMatch has a blank or invalid required value."
				        else if HasWrongRowCount or HasDuplicateKeys or HasInvalidMatchCounts then
				            error "FactTeamMatch must have two unique team rows and one home row per match."
				        else if not Table.IsEmpty(InvalidAssignments) then
				            error "FactTeamMatch roles, opponents, scores, or labels do not mirror StgMatches."
				        else TypedFact
				in
				    Output
				```

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

